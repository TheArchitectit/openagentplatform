# llama-server startup configuration
# Source this file before running llama-server, or use with the systemd service.

# Required: CUDA unified memory for 23GB model on 16GB GPU
GGML_CUDA_ENABLE_UNIFIED_MEMORY=1

# Model paths
LLAMA_MODEL=/mnt/data/models/nemotron-30b-a3b/NVIDIA-Nemotron-3-Nano-Omni-30B-A3B-Reasoning-UD-Q4_K_XL.gguf
LLAMA_MMPROJ=/mnt/data/models/nemotron-30b-a3b/mmproj-F16.gguf

# Server settings
LLAMA_HOST=0.0.0.0
LLAMA_PORT=8080
LLAMA_CTX_SIZE=131072

# KV cache quantization (saves VRAM for long contexts)
LLAMA_CACHE_TYPE_K=q4_1
LLAMA_CACHE_TYPE_V=q4_1

# Performance
LLAMA_FLASH_ATTN=on
