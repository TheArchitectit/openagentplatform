# ============================================================
# OpenAgentPlatform - Environment Configuration
# ============================================================
# Copy this file to .env and adjust as needed for your environment.
# All defaults are suitable for local development.

# ============================================================
# Application
# ============================================================
# Environment: development | staging | production
APP_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=info

# HTTP server port
HTTP_PORT=8080

# ============================================================
# Ozore AI — hosted LLM agent provider (OpenAI-compatible API)
# ============================================================
# Your API key from the Ozore dashboard
OZORE_API_KEY=
# Model identifier (e.g. ozore/custom)
OZORE_MODEL=ozore/custom
# Base URL for the Ozore API
OZORE_BASE_URL=https://ozore.com/v1

# ============================================================
# Database (PostgreSQL + TimescaleDB)
# ============================================================
# Connection string for the OAP server
# Format: postgres://user:password@host:port/dbname?sslmode=disable
POSTGRES_DSN=postgres://oap:oap@localhost:5432/oap?sslmode=disable

# Individual connection parameters (used by Docker Compose)
POSTGRES_USER=oap
POSTGRES_PASSWORD=oap
POSTGRES_DB=oap
POSTGRES_PORT=5432

# ============================================================
# NATS (Message Broker)
# ============================================================
# Connection URL for the OAP server and agents
NATS_URL=nats://localhost:4222

# mTLS certificates (leave blank for local dev without TLS)
# Generate with: ./deploy/nats/scripts/gen-certs.sh
# NATS_CERT_FILE=
# NATS_KEY_FILE=
# NATS_CA_FILE=

# NATS monitoring port
NATS_MONITOR_PORT=8222

# ============================================================
# OIDC (Authentication via Dex)
# ============================================================
# Dex issuer URL (must be reachable from web container)
OIDC_ISSUER_URL=http://localhost:5556/dex

# OAuth client credentials (must match Dex config)
OIDC_CLIENT_ID=oap-web
OIDC_CLIENT_SECRET=oap-web-secret

# Dex web UI port
DEX_PORT=5556

# ============================================================
# Session & Security
# ============================================================
# JWT signing secret (CHANGE IN PRODUCTION!)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-in-production-use-openssl-rand-hex-32

# Cookie configuration
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Session timeout (hours)
SESSION_TIMEOUT=24

# ============================================================
# Web UI
# ============================================================
# Vite dev server port
VITE_PORT=5173

# API URL for the web frontend
VITE_API_URL=http://localhost:8080

# ============================================================
# Observability (Optional)
# ============================================================
# Sentry DSN for error tracking
# SENTRY_DSN=

# Prometheus metrics port
# METRICS_PORT=9090

# ============================================================
# Agent Configuration
# ============================================================
# Default agent log level
AGENT_LOG_LEVEL=info

# Agent heartbeat interval (seconds)
AGENT_HEARTBEAT_INTERVAL=30

# ============================================================
# Feature Flags
# ============================================================
# Enable experimental features
ENABLE_A2A=true
ENABLE_LLM_AGENTS=false
